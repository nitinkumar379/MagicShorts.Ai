# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_CLIENT_ID: Your Google Cloud Console OAuth 2.0 client ID
GOOGLE_CLIENT_ID="MY_GOOGLE_CLIENT_ID"

# GOOGLE_CLIENT_SECRET: Your Google Cloud Console OAuth 2.0 client secret
GOOGLE_CLIENT_SECRET="MY_GOOGLE_CLIENT_SECRET"

# YOUTUBE_REDIRECT_URI: The redirect URI for YouTube OAuth (e.g., https://your-app.run.app/api/auth/youtube/callback)
YOUTUBE_REDIRECT_URI="MY_YOUTUBE_REDIRECT_URI"
